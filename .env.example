# Noctis Pro PACS — Required environment variables
# Copy this file to .env and fill in all values before deploying.

# Django core
SECRET_KEY=your-long-random-secret-key-here
DEBUG=False
DJANGO_SETTINGS_MODULE=noctis_pro.settings

# Public domain
DOMAIN_NAME=noctis-pro.com
ALLOWED_HOSTS=noctis-pro.com,www.noctis-pro.com

# Database (leave blank to use SQLite)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=noctispro
DB_USER=noctispro
DB_PASSWORD=change-me
DB_HOST=db
DB_PORT=5432

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Twilio (for SMS/voice notifications)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# File storage
MEDIA_ROOT=/opt/noctispro/media
STATIC_ROOT=/opt/noctispro/staticfiles
BACKUP_ROOT=/opt/noctispro/backups
BACKUP_RETENTION_DAYS=30
BACKUP_REMOTE_URL=

# HTTPS
SSL_ENABLED=True
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# Email
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# Tunnel support (optional)
NGROK_AUTHTOKEN=
NGROK_DOMAIN=
TUNNEL_URL=
