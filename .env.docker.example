# NoctisPro Docker deployment environment
# Copy to .env.docker and fill in real values before starting the stack.
#   cp .env.docker.example .env.docker

# ── Django ────────────────────────────────────────────────────────────────────
DEBUG=False
# REQUIRED in production — generate with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=
DJANGO_SETTINGS_MODULE=noctis_pro.settings

# ── Domain ────────────────────────────────────────────────────────────────────
# Your public domain as set up in Cloudflare DNS.
DOMAIN_NAME=pacs.yourdomain.com
ALLOWED_HOSTS=pacs.yourdomain.com,localhost
CSRF_TRUSTED_ORIGINS=https://pacs.yourdomain.com
# CORS_ALLOWED_ORIGINS=https://pacs.yourdomain.com

# ── Postgres ──────────────────────────────────────────────────────────────────
DB_NAME=noctispro
DB_USER=noctispro
# Use a strong random password. Generate with: openssl rand -base64 24
DB_PASSWORD=change-me

# PgBouncer auth mode — "plain" avoids "wrong password type" errors.
# Change to "md5" only if you explicitly configure md5 in PgBouncer.
PGBOUNCER_AUTH_TYPE=plain

# ── Redis / Celery ────────────────────────────────────────────────────────────
# Required in production: shared cache for rate-limiting and WebSocket routing.
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
# Worker count — auto-detected from CPU cores if unset.
# CELERY_CONCURRENCY=2
# WEB_CONCURRENCY=2

# ── DICOM receiver ────────────────────────────────────────────────────────────
# Port published on the host for CT/X-ray modalities to send images.
DICOM_PORT=11112
# AE Title the modalities must address (enter this in the scanner's config).
DICOM_AE_TITLE=NOCTIS_SCP
# Optional: restrict which IPs may send DICOM (comma-separated CIDRs/IPs).
# Leave blank to allow any (rely on per-facility allowlists in the admin instead).
# DICOM_ALLOWED_NETS=

# ── Web server tuning ─────────────────────────────────────────────────────────
# GUNICORN_TIMEOUT=21600
# GUNICORN_GRACEFUL_TIMEOUT=30
# GUNICORN_KEEPALIVE=5

# ── TLS / proxy flags (prod compose sets these automatically) ─────────────────
SSL_ENABLED=true
USE_X_FORWARDED_HOST=true
USE_X_FORWARDED_PORT=true

# ── ML Bone Reconstruction ────────────────────────────────────────────────────
# Path inside the container to a trained BoneSegNet weights file (.pth) or
# TorchScript export (.pt).  Leave unset to use the enhanced classical fallback
# (still ML-quality morphological pipeline, just no neural network inference).
# Mount the file in docker-compose.yml under volumes, then set the path here.
# Example:
#   BONE_ML_MODEL_PATH=/models/bone_seg.pt
# BONE_ML_MODEL_PATH=

# ── Security ──────────────────────────────────────────────────────────────────
# Keep False in production: patient data is served through authenticated endpoints.
SERVE_MEDIA_FILES=False

# ── Email (optional) ──────────────────────────────────────────────────────────
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=apikey
# EMAIL_HOST_PASSWORD=
# DEFAULT_FROM_EMAIL=noreply@pacs.yourdomain.com
